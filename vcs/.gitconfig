[user]
  name = Valentin Lafage
  email = valentin.lafage@celadodc-rswl.com
[pull]
  rebase = true
[push]
  default = current
[alias]
  co = checkout
  cp = cherry-pick
  br = branch
  st = status
  cm = commit -s
  amd = commit --amend --no-edit
[diff]
  tool = meld
[difftool]
  prompt = false
[core]
  editor = vim
[credential]
  helper = store
[color]
  ui = auto
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[credential "https://gitlabee.dt.renault.com"]
